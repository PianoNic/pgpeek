# Postgres credentials (used by the bundled dev postgres container)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=postgres

# pgpeek auto-connects to this on startup. In the compose stack we point at the bundled postgres.
# To use your own DB, change to: postgres://user:pass@yourhost:5432/yourdb
DATABASE_URL=postgres://postgres:postgres@postgres:5432/postgres

# Optional HTTP basic auth for the UI
PGPEEK_AUTH_USER=
PGPEEK_AUTH_PASS=

# Refuse all writes (UPDATE / DELETE / DDL). Default false.
PGPEEK_READ_ONLY=false

# Per-statement timeout in ms
PGPEEK_QUERY_TIMEOUT_MS=30000
